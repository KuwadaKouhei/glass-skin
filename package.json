{
  "name": "glass-skin",
  "version": "0.1.0",
  "description": "Skinnable background surface components for React — glass, frosted glass, reflective sheen, aurora, brushed metal, carbon fiber, paper and holographic textures.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "vite demo",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "glassmorphism",
    "glass",
    "frosted-glass",
    "backdrop-filter",
    "texture",
    "background",
    "ui",
    "component",
    "skin"
  ],
  "peerDependencies": {
    "react": ">=17"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^8.6.18",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KuwadaKouhei/glass-skin.git"
  },
  "homepage": "https://github.com/KuwadaKouhei/glass-skin#readme",
  "bugs": {
    "url": "https://github.com/KuwadaKouhei/glass-skin/issues"
  }
}
